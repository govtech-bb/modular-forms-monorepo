{
  "formId": "post-office-redirection-business",
  "title": "Redirect my business mail",
  "description": "Tell the Post Office you would like to change the address that your business mail gets delivered to.",
  "version": "1.0.0",
  "createdAt": "2026-02-04T00:00:00.000Z",
  "updatedAt": "2026-02-04T00:00:00.000Z",
  "steps": [
    {
      "stepId": "applicant-details",
      "title": "Tell us about the person submitting this application",
      "description": "Details of the person applying on behalf of the business.",
      "elements": [
        {
          "fieldId": "title",
          "label": "Title",
          "htmlType": "select",
          "options": [
            { "label": "Mr", "value": "mr" },
            { "label": "Ms", "value": "ms" },
            { "label": "Mrs", "value": "mrs" },
            { "label": "Dr", "value": "dr" }
          ],
          "validations": [
            { "required": { "value": true, "error": "Title is required" } }
          ],
          "metadata": { "pii": true, "sensitive": false }
        },
        {
          "fieldId": "first-name",
          "label": "First name",
          "htmlType": "text",
          "validations": [
            { "required": { "value": true, "error": "First name is required" } },
            { "pattern": { "value": "^\\s*[A-Za-zÀ-ÖØ-öø-ÿ](?:[A-Za-zÀ-ÖØ-öø-ÿ\\s'-]*[A-Za-zÀ-ÖØ-öø-ÿ])?\\s*$", "error": "First name must contain only letters, hyphens, or apostrophes" } },
            { "minLength": { "value": 2, "error": "First name must be at least 2 characters" } }
          ],
          "metadata": { "pii": true, "sensitive": false }
        },
        {
          "fieldId": "middle-name",
          "label": "Middle name",
          "hint": "Enter all middle names in order",
          "htmlType": "text",
          "validations": [
            { "required": { "value": false, "error": "" } },
            { "pattern": { "value": "^\\s*[A-Za-zÀ-ÖØ-öø-ÿ](?:[A-Za-zÀ-ÖØ-öø-ÿ\\s'-]*[A-Za-zÀ-ÖØ-öø-ÿ])?\\s*$", "error": "Middle name must contain only letters, hyphens, or apostrophes" } },
            { "minLength": { "value": 2, "error": "Middle name must be at least 2 characters" } }
          ],
          "metadata": { "pii": true, "sensitive": false }
        },
        {
          "fieldId": "last-name",
          "label": "Last name",
          "htmlType": "text",
          "validations": [
            { "required": { "value": true, "error": "Last name is required" } },
            { "pattern": { "value": "^\\s*[A-Za-zÀ-ÖØ-öø-ÿ](?:[A-Za-zÀ-ÖØ-öø-ÿ\\s'-]*[A-Za-zÀ-ÖØ-öø-ÿ])?\\s*$", "error": "Last name must contain only letters, hyphens, or apostrophes" } },
            { "minLength": { "value": 2, "error": "Last name must be at least 2 characters" } }
          ],
          "metadata": { "pii": true, "sensitive": false }
        },
        {
          "fieldId": "national-id-number",
          "label": "National Identification (ID) number",
          "htmlType": "text",
          "validations": [
            { "required": { "value": true, "error": "National ID number is required" } },
            { "pattern": { "value": "^\\d{6}-\\d{4}$", "error": "Enter a valid ID number (for example, 850101-0001)" } }
          ],
          "skipValidationWhenShowHideOpen": "use-passport-instead",
          "metadata": { "pii": true, "sensitive": true }
        },
        {
          "fieldId": "passport-details",
          "label": "",
          "htmlType": "showHide",
          "validations": [
            { "required": { "value": false, "error": "" } }
          ],
          "showHide": {
            "summary": "Use passport number instead",
            "stateFieldId": "use-passport-instead",
            "description": "If you don't have a National ID number, you can use your passport number instead.",
            "elements": [
              {
                "fieldId": "passport-number",
                "label": "Passport Number",
                "placeholder": "",
                "htmlType": "text",
                "validations": [
                  { "required": { "value": true, "error": "Passport number is required" } },
                  { "minLength": { "value": 6, "error": "Passport number must be at least 6 characters" } }
                ],
                "metadata": { "pii": true, "sensitive": true }
              }
            ]
          },
          "metadata": { "pii": false, "sensitive": false }
        },
        {
          "fieldId": "email",
          "label": "Email address",
          "htmlType": "email",
          "validations": [
            { "required": { "value": true, "error": "Email address is required" } }
          ],
          "metadata": { "pii": true, "sensitive": false }
        },
        {
          "fieldId": "telephone",
          "label": "Telephone number",
          "htmlType": "tel",
          "validations": [
            { "required": { "value": true, "error": "Telephone number is required" } },
            { "pattern": { "value": "^\\d{3}[- ]?\\d{4}$|^(?:\\d{1,2}[- ]?)?\\d{3}[- ]?\\d{3}[- ]?\\d{4}$", "error": "Please enter a valid phone number (for example, 2345678, 1-246-234-5678, or 1 246 234 5678)" } }
          ],
          "metadata": { "pii": true, "sensitive": false }
        }
      ]
    },
    {
      "stepId": "business-details",
      "title": "Tell us about the business",
      "elements": [
        {
          "fieldId": "business-name",
          "label": "Business name",
          "htmlType": "text",
          "validations": [
            { "required": { "value": true, "error": "Business name is required" } },
            { "minLength": { "value": 5, "error": "Business name must be at least 5 characters" } }
          ],
          "metadata": { "pii": false, "sensitive": false }
        },
        {
          "fieldId": "business-registration-number",
          "label": "Registration number",
          "htmlType": "text",
          "validations": [
            { "required": { "value": true, "error": "Business registration number is required" } },
            { "minLength": { "value": 5, "error": "Business registration number must be at least 5 characters" } }
          ],
          "metadata": { "pii": false, "sensitive": true }
        }
      ]
    },
    {
      "stepId": "current-address",
      "title": "Current address of the business",
      "elements": [
        {
          "fieldId": "address-line-1",
          "label": "Address line 1",
          "htmlType": "text",
          "validations": [
            { "required": { "value": true, "error": "Address line 1 is required" } },
            { "minLength": { "value": 5, "error": "Address must be at least 5 characters" } }
          ],
          "metadata": { "pii": true, "sensitive": false }
        },
        {
          "fieldId": "address-line-2",
          "label": "Address line 2",
          "hint": "Optional",
          "htmlType": "text",
          "metadata": { "pii": true, "sensitive": false }
        },
        {
          "fieldId": "parish",
          "label": "Parish",
          "htmlType": "select",
          "options": [
            { "label": "Christ Church", "value": "christ-church" },
            { "label": "Saint Andrew", "value": "saint-andrew" },
            { "label": "Saint George", "value": "saint-george" },
            { "label": "Saint James", "value": "saint-james" },
            { "label": "Saint John", "value": "saint-john" },
            { "label": "Saint Joseph", "value": "saint-joseph" },
            { "label": "Saint Lucy", "value": "saint-lucy" },
            { "label": "Saint Michael", "value": "saint-michael" },
            { "label": "Saint Peter", "value": "saint-peter" },
            { "label": "Saint Philip", "value": "saint-philip" },
            { "label": "Saint Thomas", "value": "saint-thomas" }
          ],
          "validations": [
            { "required": { "value": true, "error": "Parish is required" } }
          ],
          "metadata": { "pii": true, "sensitive": false }
        },
        {
          "fieldId": "postcode",
          "label": "Postcode",
          "hint": "For example, BB17004 (optional)",
          "htmlType": "text",
          "validations": [
            { "pattern": { "value": "^BB\\\\d{5}$", "error": "Enter a valid postcode (for example, BB17004)" } }
          ],
          "metadata": { "pii": true, "sensitive": false }
        }
      ]
    },
    {
      "stepId": "position-details",
      "title": "Tell us what position you hold in the business",
      "elements": [
        {
          "fieldId": "position",
          "label": "Position",
          "hint": "For example, are you a director, manager, or an appointed agent?",
          "htmlType": "text",
          "placeholder": "",
          "validations": [
            { "required": { "value": true, "error": "Position is required" } },
            { "minLength": { "value": 5, "error": "Position must be at least 5 characters" } }
          ]
        }
      ]
    },
    {
      "stepId": "new-address",
      "title": "Where should we redirect the mail?",
      "elements": [
        {
          "fieldId": "address-line-1",
          "label": "Address line 1",
          "htmlType": "text",
          "validations": [
            { "required": { "value": true, "error": "Address line 1 is required" } },
            { "minLength": { "value": 5, "error": "Address must be at least 5 characters" } }
          ],
          "metadata": { "pii": true, "sensitive": false }
        },
        {
          "fieldId": "address-line-2",
          "label": "Address line 2",
          "hint": "Optional",
          "htmlType": "text",
          "metadata": { "pii": true, "sensitive": false }
        },
        {
          "fieldId": "parish",
          "label": "Parish",
          "htmlType": "select",
          "options": [
            { "label": "Christ Church", "value": "christ-church" },
            { "label": "Saint Andrew", "value": "saint-andrew" },
            { "label": "Saint George", "value": "saint-george" },
            { "label": "Saint James", "value": "saint-james" },
            { "label": "Saint John", "value": "saint-john" },
            { "label": "Saint Joseph", "value": "saint-joseph" },
            { "label": "Saint Lucy", "value": "saint-lucy" },
            { "label": "Saint Michael", "value": "saint-michael" },
            { "label": "Saint Peter", "value": "saint-peter" },
            { "label": "Saint Philip", "value": "saint-philip" },
            { "label": "Saint Thomas", "value": "saint-thomas" }
          ],
          "validations": [
            { "required": { "value": true, "error": "New parish is required" } }
          ],
          "metadata": { "pii": true, "sensitive": false }
        },
        {
          "fieldId": "postcode",
          "label": "Postcode",
          "hint": "For example, BB17004 (optional)",
          "htmlType": "text",
          "validations": [
            { "pattern": { "value": "^BB\\\\d{5}$", "error": "Enter a valid postcode (for example, BB17004)" } }
          ],
          "metadata": { "pii": true, "sensitive": false }
        },
        {
          "fieldId": "redirection-start-date",
          "label": "When do you want the redirection to start?",
          "htmlType": "date",
          "validations": [
            { "required": { "value": true, "error": "Start date is required" } },
            { "futureOrToday": { "value": true, "error": "Start date must be today or later" } }
          ]
        },
        {
          "fieldId": "redirection-end-date",
          "label": "When do you want the redirection to end?",
          "hint": "A redirection notice lasts for a maximum of 6 months.",
          "htmlType": "date",
          "validations": [
            { "required": { "value": true, "error": "End date is required" } },
            { "after": { "value": "redirection-start-date", "error": "End date must be after start date" } }
          ]
        }
      ]
    },
    {
      "stepId": "check-your-answers",
      "title": "Check your answers",
      "elements": []
    },
    {
      "stepId": "declaration",
      "title": "Declaration",
      "elements": [
	      {
          "fieldId": "confirmation",
          "label": "I confirm that my information is correct and I am happy for it to be verified. I understand that false details may lead to my application being rejected, and that the Government of Barbados will keep my information confidential.",
          "htmlType": "checkbox",
          "validations": [
            { "required": { "value": true, "error": "You must confirm the declaration to continue" } }
          ]
        },
        {
          "fieldId": "date",
          "label": "Date of declaration",
          "placeholder": "",
          "htmlType": "date",
          "validations": [
            { "required": { "value": true, "error": "Date is required" } },
            { "pastOrToday": { "value": true, "error": "Date of declaration must be today or earlier" } }
          ]
        }
      ]
    }
  ],
  "processors": [
    {
      "type": "payment",
      "config": {
        "currency": "BBD",
        "amount": 30,
        "provider": "ezpay-plus",
        "description": "Post Office business mail redirection fee"
      }
    },
    {
      "type": "email",
      "config": {
        "to": "post-office-redirection@gov.bb",
        "subject": "New Business Mail Redirection Submission",
        "template": "post-office-redirection-business-submission"
      }
    }
  ]
}